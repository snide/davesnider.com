{
  "name": "ds",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite dev --port 5177",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src && pnpm run check",
    "format-check": "prettier --check .",
    "format-write": "prettier --write .",
    "lint:eslint": "eslint src",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tsc": "svelte-kit sync && tsc --noEmit",
    "watchfiles": "tsx ./src/scripts/watch.ts",
    "uploadfiles": "tsx ./src/scripts/upload.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "tunnel": "cloudflared tunnel run local-dev",
    "worker:github": "cd workers/activity-github && wrangler dev --var INGEST_URL:https://local.davesnider.com/api/activity/ingest/github",
    "worker:bluesky": "cd workers/activity-bluesky && wrangler dev --var INGEST_URL:https://local.davesnider.com/api/activity/ingest/bluesky",
    "worker:reddit": "cd workers/activity-reddit && wrangler dev --var INGEST_URL:https://local.davesnider.com/api/activity/ingest/reddit",
    "worker:hackernews": "cd workers/activity-hackernews && wrangler dev --var INGEST_URL:https://local.davesnider.com/api/activity/ingest/hackernews",
    "worker:bgg": "cd workers/activity-bgg && wrangler dev --var INGEST_URL:https://local.davesnider.com/api/activity/ingest/bgg",
    "worker:steam": "cd workers/activity-steam && wrangler dev --var INGEST_URL:https://local.davesnider.com/api/activity/ingest/steam"
  },
  "dependencies": {
    "@fontsource-variable/aleo": "^5.2.7",
    "@libsql/client": "^0.17.3",
    "@shikijs/transformers": "^4.2.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@threlte/core": "^8.3.1",
    "@threlte/extras": "^9.7.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "isomorphic-dompurify": "^3.16.0",
    "marked": "^18.0.5",
    "mdsvex": "^0.12.7",
    "mode-watcher": "^1.1.0",
    "shiki": "^4.2.0",
    "svelte": "^5.56.1",
    "three": "^0.182.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1061.0",
    "@google-cloud/storage": "^7.19.0",
    "@google-cloud/vision": "^5.3.6",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "chokidar": "^5.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-plugin-svelte": "^3.19.0",
    "mime": "^4.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^4.1.0",
    "svelte-check": "^4.6.0",
    "svelte-eslint-parser": "^1.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.98.0"
  },
  "packageManager": "pnpm@9.11.0+sha512.0a203ffaed5a3f63242cd064c8fb5892366c103e328079318f78062f24ea8c9d50bc6a47aa3567cabefd824d170e78fa2745ed1f16b132e16436146b7688f19b",
  "engines": {
    "node": ">=22.0.0"
  }
}
