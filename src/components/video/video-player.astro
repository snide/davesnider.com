---
interface Props {
  src: string;
  autoplay?: boolean;
  loop?: boolean;
  muted?: boolean;
  controls?: boolean;
  poster?: string;
  caption?: string;
}

const {
  src,
  autoplay = false,
  loop = false,
  muted = false,
  controls = true,
  poster,
  caption
} = Astro.props;
---

<div class="videoPlayer">
  <video
    controls={controls}
    loop={loop}
    muted={muted || autoplay}
    autoplay={autoplay}
    playsinline
    preload={autoplay ? 'metadata' : 'none'}
    poster={poster}
  >
    <source src={src} type="video/mp4" />
  </video>
  {caption && <p>{caption}</p>}
</div>

<style>
  p {
    font-size: 0.875rem;
    font-family: var(--codeFont);
    text-align: center;
    color: var(--subtle);
  }
</style>
